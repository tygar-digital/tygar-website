---
const { items } = Astro.props;
const marqueeItems = items || [
  'Professionelle Website','Online gefunden werden','Mehr Anfragen','Terminbuchung',
  'Google-Sichtbarkeit','Mobiloptimiert','Rundum-sorglos','Faire Preise',
  'DSGVO-konform','Persönliche Betreuung','In 3 Wochen live','Lokale Unternehmen'
];
const doubled = [...marqueeItems, ...marqueeItems];
---

<div class="overflow-hidden border-y py-3.5 group"
  style="border-color:rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);
         -webkit-mask-image:linear-gradient(90deg,transparent 0%,black 8%,black 92%,transparent 100%);
         mask-image:linear-gradient(90deg,transparent 0%,black 8%,black 92%,transparent 100%);">
  <div class="flex w-max animate-marquee group-hover:[animation-play-state:paused]">
    {doubled.map(item => (
      <span class="inline-flex items-center gap-4 font-heading font-bold text-xs tracking-[0.1em] uppercase text-brand-muted px-4 whitespace-nowrap transition-colors hover:text-brand-text cursor-default">
        {item}
        <span class="text-brand-cyan opacity-70 text-[0.55rem]">✦</span>
      </span>
    ))}
  </div>
</div>
