---
const { data } = Astro.props;
const accentBorder: Record<string,string> = { emerald: '#DDD5C8', cyan: '#DDD5C8', violet: '#DDD5C8' };
const accentGlow: Record<string,string> = {
  emerald: '0 8px 30px rgba(0,0,0,0.10)', cyan: '0 8px 30px rgba(0,0,0,0.10)', violet: '0 8px 30px rgba(0,0,0,0.10)',
};
const tagBg: Record<string,string> = { emerald: 'rgba(16,44,38,0.08)', cyan: 'rgba(16,44,38,0.08)', violet: 'rgba(16,44,38,0.08)' };
const tagBorder: Record<string,string> = { emerald: 'rgba(16,44,38,0.20)', cyan: 'rgba(16,44,38,0.20)', violet: 'rgba(16,44,38,0.20)' };
const tagColor: Record<string,string> = { emerald: '#102C26', cyan: '#102C26', violet: '#102C26' };
---
<section id="beispiele" class="bg-brand-bg">
  <div class="max-w-[1160px] mx-auto px-8 py-[108px]">

    <div class="flex items-center gap-2 text-[0.72rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-text mb-3">
      <span class="w-[18px] h-[2px] flex-shrink-0" style="background:#102C26"></span>
      {data.label}
    </div>
    <h2 class="font-heading font-black leading-[1.08] tracking-[-0.02em] mb-4"
      style="font-size:clamp(2rem,4.5vw,3.25rem)">
      {data.heading[0]}<br/>
      <span style="color:#102C26">{data.heading[1]}</span>
    </h2>
    <p class="text-brand-text leading-[1.75] mb-12 max-w-[580px]">{data.subtext}</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {data.items.map((item: any) => (
        <a href={item.preview_url} target="_blank" rel="noopener noreferrer"
          class="showcase-card rounded-card border flex flex-col overflow-hidden transition-all duration-[280ms] hover:-translate-y-2 bg-white shadow-card no-underline"
          style={`border-color:${accentBorder[item.accent]};`}>

          <div class="relative bg-brand-surface overflow-hidden" style="height:200px">
            <div class="flex items-center gap-1.5 px-3 py-2 border-b border-brand-border bg-white">
              <span class="w-2.5 h-2.5 rounded-full bg-red-500/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-green-500/60"></span>
              <div class="ml-2 flex-1 h-5 rounded bg-brand-border/50 flex items-center px-2">
                <span class="text-[0.6rem] text-brand-muted truncate">{item.preview_url}</span>
              </div>
            </div>
            <div class="absolute inset-0 top-[33px] flex items-center justify-center bg-brand-surface">
              <div class="text-center">
                <div class="w-12 h-12 rounded-full mx-auto mb-3 flex items-center justify-center"
                  style={`background:${tagBg[item.accent]};border:1px solid ${tagBorder[item.accent]}`}>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                    style={`stroke:${tagColor[item.accent]}`}>
                    <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                  </svg>
                </div>
                <p class="text-xs text-brand-muted">Vorschau demnächst verfügbar</p>
              </div>
            </div>
            <iframe src={new URL(item.preview_url).pathname + '/index.html'} loading="lazy" tabindex="-1" title={item.title}
              class="w-full border-0 pointer-events-none relative z-10"
              style="height:400px;transform:scale(0.5);transform-origin:top left;width:200%">
            </iframe>
          </div>

          <div class="p-6 flex flex-col gap-3 flex-1">
            <span class="inline-block text-[0.72rem] font-heading font-semibold px-3 py-1 rounded-full border self-start"
              style={`background:${tagBg[item.accent]};border-color:${tagBorder[item.accent]};color:${tagColor[item.accent]}`}>
              {item.tag}
            </span>
            <h3 class="font-heading font-bold text-brand-heading text-lg">{item.title}</h3>
            <p class="text-brand-text text-sm leading-relaxed flex-1">{item.text}</p>
            <span class="text-sm font-heading font-bold mt-1"
              style={`color:${tagColor[item.accent]}`}>
              {item.cta}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase-card {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .showcase-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.10);
  }
</style>
