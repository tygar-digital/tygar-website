---
const { data } = Astro.props;
const accentBorder: Record<string,string> = {
  emerald: 'rgba(52,211,153,.3)',
  cyan:    'rgba(34,211,238,.3)',
  violet:  'rgba(167,139,250,.3)',
};
const accentGlow: Record<string,string> = {
  emerald: '0 12px 48px rgba(52,211,153,.20),0 0 0 1px rgba(52,211,153,.2)',
  cyan:    '0 12px 48px rgba(34,211,238,.20),0 0 0 1px rgba(34,211,238,.2)',
  violet:  '0 12px 48px rgba(167,139,250,.20),0 0 0 1px rgba(167,139,250,.2)',
};
const tagBg: Record<string,string> = {
  emerald: 'rgba(52,211,153,0.10)',
  cyan:    'rgba(34,211,238,0.10)',
  violet:  'rgba(167,139,250,0.10)',
};
const tagBorder: Record<string,string> = {
  emerald: 'rgba(52,211,153,0.30)',
  cyan:    'rgba(34,211,238,0.30)',
  violet:  'rgba(167,139,250,0.30)',
};
const tagColor: Record<string,string> = {
  emerald: '#34D399', cyan: '#22D3EE', violet: '#A78BFA',
};
---
<section id="beispiele" class="border-t border-brand-border">
  <div class="max-w-[1160px] mx-auto px-8 py-[108px]">

    <div class="flex items-center gap-2 text-[0.72rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-secondary mb-3">
      <span class="w-[18px] h-[2px] flex-shrink-0" style="background:linear-gradient(90deg,#34D399,#22D3EE,#A78BFA)"></span>
      {data.label}
    </div>
    <h2 class="font-heading font-black leading-[1.08] tracking-[-0.03em] mb-4"
      style="font-size:clamp(2rem,4.5vw,3.25rem)">
      {data.heading[0]}<br/>
      <span class="bg-clip-text text-transparent"
        style="background-image:linear-gradient(90deg,#34D399,#22D3EE,#A78BFA)">{data.heading[1]}</span>
    </h2>
    <p class="text-brand-secondary leading-[1.75] mb-12 max-w-[580px]">{data.subtext}</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {data.items.map((item: any) => (
        <div class="rounded-card border flex flex-col overflow-hidden transition-all duration-[280ms] hover:-translate-y-2"
          style={`background:rgba(39,39,42,0.55);backdrop-filter:blur(12px);
                  border-color:${accentBorder[item.accent]};`}
          onmouseenter={`this.style.boxShadow='${accentGlow[item.accent]}'`}
          onmouseleave={`this.style.boxShadow='none'`}>

          <!-- Browser preview -->
          <div class="relative bg-brand-bg overflow-hidden" style="height:200px">
            <div class="flex items-center gap-1.5 px-3 py-2 border-b border-brand-border bg-brand-surface">
              <span class="w-2.5 h-2.5 rounded-full bg-red-500/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-green-500/60"></span>
              <div class="ml-2 flex-1 h-5 rounded bg-brand-border/50 flex items-center px-2">
                <span class="text-[0.6rem] text-brand-muted truncate">{item.preview_url}</span>
              </div>
            </div>
            <iframe src={item.preview_url} loading="lazy" tabindex="-1" title={item.title}
              class="w-full border-0 pointer-events-none"
              style="height:400px;transform:scale(0.5);transform-origin:top left;width:200%">
            </iframe>
          </div>

          <div class="p-6 flex flex-col gap-3 flex-1">
            <span class="inline-block text-[0.72rem] font-heading font-semibold px-3 py-1 rounded-full border self-start"
              style={`background:${tagBg[item.accent]};border-color:${tagBorder[item.accent]};color:${tagColor[item.accent]}`}>
              {item.tag}
            </span>
            <h3 class="font-heading font-bold text-brand-heading text-lg">{item.title}</h3>
            <p class="text-brand-secondary text-sm leading-relaxed flex-1">{item.text}</p>
            <a href={item.preview_url} target="_blank" rel="noopener noreferrer"
              class="text-sm font-heading font-bold transition-colors mt-1"
              style={`color:${tagColor[item.accent]}`}>
              {item.cta}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
