---
const { data } = Astro.props;
const FORMSPREE_ID = 'YOUR_FORMSPREE_ID'; // ← hier deine Formspree-ID eintragen
---
<section id="kontakt" class="bg-brand-surface">
  <div class="max-w-[1160px] mx-auto px-8 py-[108px]">

    <div class="flex items-center gap-2 text-[0.72rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-text mb-3">
      <span class="w-[18px] h-[2px] flex-shrink-0" style="background:#2D6A4F"></span>
      {data.label}
    </div>
    <h2 class="font-heading font-black leading-[1.08] tracking-[-0.02em] mb-4"
      style="font-size:clamp(2rem,4.5vw,3.25rem)">
      {data.heading[0]}<br/>
      <span style="color:#2D6A4F">{data.heading[1]}</span>
    </h2>
    <p class="text-brand-text leading-[1.75] mb-12 max-w-[560px]">{data.subtext}</p>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_420px] gap-12 items-start">

      <!-- Kontaktformular (Formspree) -->
      <div class="rounded-card border border-brand-border p-8 bg-white shadow-card">
        <form id="contact-form" action={`https://formspree.io/f/${FORMSPREE_ID}`} method="POST"
          class="flex flex-col gap-5">

          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-[0.68rem] font-heading font-bold tracking-[0.1em] uppercase text-brand-muted">
                {data.form.label_firstname}
              </label>
              <input type="text" name="vorname" required
                class="bg-brand-bg border border-brand-border rounded-lg px-4 py-3 text-base text-brand-heading font-body outline-none transition-colors focus:border-brand-emerald" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[0.68rem] font-heading font-bold tracking-[0.1em] uppercase text-brand-muted">
                {data.form.label_lastname}
              </label>
              <input type="text" name="nachname" required
                class="bg-brand-bg border border-brand-border rounded-lg px-4 py-3 text-base text-brand-heading font-body outline-none transition-colors focus:border-brand-emerald" />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[0.68rem] font-heading font-bold tracking-[0.1em] uppercase text-brand-muted">
              {data.form.label_email}
            </label>
            <input type="email" name="email" required
              class="bg-brand-bg border border-brand-border rounded-lg px-4 py-3 text-base text-brand-heading font-body outline-none transition-colors focus:border-brand-emerald" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[0.68rem] font-heading font-bold tracking-[0.1em] uppercase text-brand-muted">
              {data.form.label_service}
            </label>
            <select name="service"
              class="bg-brand-bg border border-brand-border rounded-lg px-4 py-3 text-base text-brand-heading font-body outline-none transition-colors focus:border-brand-emerald appearance-none">
              {data.form.service_options.map((opt: string) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[0.68rem] font-heading font-bold tracking-[0.1em] uppercase text-brand-muted">
              {data.form.label_message}
            </label>
            <textarea name="projekt" rows="5" required
              class="bg-brand-bg border border-brand-border rounded-lg px-4 py-3 text-base text-brand-heading font-body outline-none transition-colors focus:border-brand-emerald resize-y min-h-[120px]">
            </textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="_gotcha" class="hidden" />
          <!-- Redirect nach Submit -->
          <input type="hidden" name="_next" value="https://tygar-digital.de/?sent=1" />

          <p class="text-xs text-brand-muted">
            Mit dem Absenden stimmst du unserer
            <a href="/datenschutz" class="underline hover:text-brand-text transition-colors">Datenschutzerklärung</a> zu.
          </p>

          <button type="submit" id="submit-btn"
            class="w-full font-heading font-bold text-sm py-3.5 rounded-lg text-white transition-all hover:-translate-y-0.5 hover:shadow-card-hover"
            style="background:#2D6A4F">
            {data.form.submit_label}
          </button>
        </form>
      </div>

      <!-- Info Boxes -->
      <div class="flex flex-col gap-4">
        {data.info_boxes.map((box: any) => (
          <div class="rounded-card border border-brand-border p-5 flex items-center gap-4 bg-white shadow-card">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background:rgba(45,106,79,0.10);color:#2D6A4F"
              set:html={box.icon_svg}>
            </div>
            <div>
              <div class="text-[0.68rem] font-heading font-bold tracking-[0.08em] uppercase text-brand-muted mb-0.5">
                {box.label}
              </div>
              <div class="text-brand-text text-sm font-body">
                {box.href
                  ? <a href={box.href} class="border-b border-current hover:opacity-80 transition-opacity">{box.value}</a>
                  : box.value
                }
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
