---
const { data } = Astro.props;
const { badge, headline, subtext, cta_primary, cta_secondary, kpis, trust_items, collage } = data;
---

<section id="hero" class="relative overflow-hidden pt-[calc(72px+100px)] pb-[120px]">

  <!-- Subtle radial gradient accent -->
  <div class="absolute inset-0 pointer-events-none z-0"
    style="background: radial-gradient(ellipse 60% 50% at 80% 20%, rgba(82,183,136,0.06), transparent)">
  </div>

  <div class="max-w-[1160px] mx-auto px-8 relative z-10">

    <!-- Split: Text left, Collage right -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_480px] gap-12 lg:gap-14 items-center">

      <!-- Text Column -->
      <div>
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 border rounded-full px-4 py-1.5 text-sm font-medium text-brand-emerald mb-7 animate-badge-in"
          style="background:rgba(45,106,79,0.08);border-color:rgba(45,106,79,0.25)">
          <span class="w-2 h-2 rounded-full bg-brand-emerald animate-pulse-dot"
            style="box-shadow:0 0 8px #2D6A4F"></span>
          {badge}
        </div>

        <!-- Headline -->
        <h1 class="font-heading font-black leading-[1.05] tracking-[-0.02em] mb-7"
          style="font-size: clamp(2.4rem, 5vw, 3.8rem)">
          {headline.map((line: string, i: number) => (
            i < 2
              ? <Fragment>{line}<br/></Fragment>
              : <span style="color:#2D6A4F">{line}{i < headline.length - 1 ? <br/> : ''}</span>
          ))}
        </h1>

        <p class="text-brand-text leading-[1.8] mb-10 max-w-[520px]"
          style="font-size: clamp(1rem, 2vw, 1.1rem)">
          {subtext}
        </p>

        <div class="flex gap-4 flex-wrap">
          <a href={cta_primary.href}
            class="font-heading font-bold text-sm px-8 py-3.5 rounded-lg text-white transition-all hover:-translate-y-0.5 hover:opacity-90"
            style="background:#2D6A4F">
            {cta_primary.label}
          </a>
          <a href={cta_secondary.href}
            class="font-heading font-semibold text-sm px-8 py-3.5 rounded-lg transition-all hover:bg-[#2D6A4F] hover:text-white"
            style="border:2px solid #2D6A4F;color:#2D6A4F;background:transparent">
            {cta_secondary.label}
          </a>
        </div>
      </div>

      <!-- Bento Grid (Desktop only) -->
      {collage && (
        <div class="hidden lg:grid gap-3" style="grid-template-columns:1fr 1fr;grid-template-rows:auto auto auto">

          <!-- Browser Mockup — spans full width -->
          <div class="col-span-2 rounded-2xl border border-brand-border overflow-hidden bg-white bento-card"
            style="box-shadow:0 2px 20px rgba(0,0,0,0.06);animation-delay:0.1s">
            <!-- Chrome bar -->
            <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-brand-border bg-brand-surface/50">
              <span class="w-[7px] h-[7px] rounded-full" style="background:#EF4444"></span>
              <span class="w-[7px] h-[7px] rounded-full" style="background:#F59E0B"></span>
              <span class="w-[7px] h-[7px] rounded-full" style="background:#22C55E"></span>
              <div class="flex-1 flex justify-center ml-4">
                <div class="flex items-center gap-1.5 rounded-md px-3 py-1" style="background:rgba(0,0,0,0.04)">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#8A8AAA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  <span class="text-[10px] text-brand-muted font-body">friseursalon-ammarkt.de</span>
                </div>
              </div>
            </div>
            <!-- Website content -->
            {collage.browser?.src ? (
              <img src={collage.browser.src} alt={collage.browser.alt}
                class="w-full h-[200px] object-cover object-top" loading="eager" decoding="async" />
            ) : (
              <div class="p-5" style="background:linear-gradient(180deg, #fafaf8 0%, #fff 100%)">
                <!-- Nav skeleton -->
                <div class="flex items-center justify-between mb-5">
                  <div class="h-3 w-24 rounded-full" style="background:rgba(45,106,79,0.15)"></div>
                  <div class="flex gap-4">
                    <div class="h-2 w-12 rounded-full" style="background:rgba(0,0,0,0.06)"></div>
                    <div class="h-2 w-12 rounded-full" style="background:rgba(0,0,0,0.06)"></div>
                    <div class="h-2 w-12 rounded-full" style="background:rgba(0,0,0,0.06)"></div>
                  </div>
                </div>
                <!-- Hero skeleton -->
                <div class="flex gap-5">
                  <div class="flex-1">
                    <div class="h-5 w-4/5 rounded mb-2" style="background:rgba(0,0,0,0.07)"></div>
                    <div class="h-5 w-3/5 rounded mb-4" style="background:rgba(0,0,0,0.05)"></div>
                    <div class="h-2 w-full rounded-full mb-1.5" style="background:rgba(0,0,0,0.04)"></div>
                    <div class="h-2 w-5/6 rounded-full mb-4" style="background:rgba(0,0,0,0.03)"></div>
                    <div class="h-7 w-28 rounded-lg" style="background:rgba(45,106,79,0.18)"></div>
                  </div>
                  <div class="w-32 h-24 rounded-lg flex-shrink-0" style="background:rgba(45,106,79,0.06)"></div>
                </div>
              </div>
            )}
          </div>

          <!-- Stats Card -->
          <div class="rounded-2xl border border-brand-border p-5 bg-white flex flex-col justify-between bento-card"
            style="box-shadow:0 2px 20px rgba(0,0,0,0.06);animation-delay:0.2s">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center mb-4"
              style="background:rgba(45,106,79,0.08)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
                <polyline points="16 7 22 7 22 13"/>
              </svg>
            </div>
            <!-- Mini chart bars -->
            <div class="flex items-end gap-1.5 mb-4 h-10">
              <div class="w-full rounded-sm" style="height:30%;background:rgba(45,106,79,0.10)"></div>
              <div class="w-full rounded-sm" style="height:45%;background:rgba(45,106,79,0.14)"></div>
              <div class="w-full rounded-sm" style="height:35%;background:rgba(45,106,79,0.12)"></div>
              <div class="w-full rounded-sm" style="height:60%;background:rgba(45,106,79,0.18)"></div>
              <div class="w-full rounded-sm" style="height:50%;background:rgba(45,106,79,0.16)"></div>
              <div class="w-full rounded-sm" style="height:75%;background:rgba(45,106,79,0.22)"></div>
              <div class="w-full rounded-sm" style="height:90%;background:rgba(45,106,79,0.30)"></div>
              <div class="w-full rounded-sm" style="height:100%;background:#2D6A4F"></div>
            </div>
            <div>
              <div class="font-heading font-black text-2xl text-brand-emerald leading-none tracking-tight">{collage.stats.value}</div>
              <div class="text-[11px] text-brand-muted font-body mt-1.5 leading-snug">{collage.stats.label}</div>
            </div>
          </div>

          <!-- Google Review Card -->
          <div class="rounded-2xl border border-brand-border p-5 bg-white flex flex-col justify-between bento-card"
            style="box-shadow:0 2px 20px rgba(0,0,0,0.06);animation-delay:0.3s">
            <div>
              <div class="flex items-center gap-2 mb-3">
                <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span class="text-xs font-heading font-semibold text-brand-heading">Google Bewertung</span>
              </div>
              <div class="flex gap-0.5 mb-3">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <p class="text-[13px] text-brand-text leading-relaxed italic">
                &ldquo;{collage.review.text}&rdquo;
              </p>
            </div>
            <div class="flex items-center gap-2.5 mt-4 pt-3 border-t border-brand-border">
              {collage.customer?.src && (
                <img src={collage.customer.src} alt={collage.customer.alt}
                  class="w-7 h-7 rounded-full object-cover object-top border border-brand-border" loading="eager" decoding="async" />
              )}
              <span class="text-[11px] text-brand-muted font-heading">{collage.review.author}</span>
            </div>
          </div>

          <!-- Notification Toast — spans full width -->
          <div class="col-span-2 rounded-2xl border border-brand-border px-5 py-3.5 bg-white flex items-center gap-4 bento-card"
            style="box-shadow:0 2px 20px rgba(0,0,0,0.06);animation-delay:0.4s">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0"
              style="background:rgba(45,106,79,0.08)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"/>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-[13px] font-heading font-bold text-brand-heading">{collage.notification.title}</div>
              <div class="text-[11px] text-brand-muted">{collage.notification.text}</div>
            </div>
            <div class="flex items-center gap-1.5 flex-shrink-0">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-emerald animate-pulse-dot"></span>
              <span class="text-[11px] text-brand-emerald font-heading font-semibold">{collage.notification.time}</span>
            </div>
          </div>

        </div>
      )}

    </div>

    <!-- KPIs -->
    <div class="flex mt-14 border border-brand-border rounded-card overflow-hidden bg-white shadow-card">
      {kpis.map((k: any, i: number) => (
        <div class:list={['flex-1 px-6 py-5 text-center', i < kpis.length - 1 ? 'border-r border-brand-border' : '']}>
          <div class="font-heading font-black text-2xl text-brand-emerald">
            {k.value}
          </div>
          <div class="text-xs text-brand-muted font-body mt-1">{k.label}</div>
        </div>
      ))}
    </div>

    <!-- Trust-Leiste -->
    {trust_items && trust_items.length > 0 && (
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mt-6">
        {trust_items.map((item: string) => (
          <span class="flex items-center gap-1.5 text-xs text-brand-text">
            <span class="text-brand-emerald">✔</span>{item}
          </span>
        ))}
      </div>
    )}

  </div>
</section>

<style>
  .bento-card {
    opacity: 0;
    transform: translateY(16px);
    animation: bentoReveal 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .bento-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.10) !important;
    transform: translateY(-2px);
  }
  @keyframes bentoReveal {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
