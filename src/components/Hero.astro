---
const { data } = Astro.props;
const { badge, headline, subtext, cta_primary, cta_secondary, kpis, trust_items, collage } = data;
---

<section id="hero" class="relative overflow-hidden pt-[calc(72px+100px)] pb-[120px]">

  <!-- Dot-grid overlay -->
  <div class="absolute inset-0 pointer-events-none z-0"
    style="background-image: radial-gradient(rgba(255,255,255,0.055) 1px, transparent 1px);
           background-size: 36px 36px;
           -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
           mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);">
  </div>

  <!-- Animated Orbs -->
  <div class="absolute w-[700px] h-[700px] rounded-full pointer-events-none will-change-transform animate-orb-1"
    style="top:-200px;right:-80px;filter:blur(80px);background:radial-gradient(circle,rgba(34,211,238,0.10) 0%,transparent 70%)"></div>
  <div class="absolute w-[500px] h-[500px] rounded-full pointer-events-none will-change-transform animate-orb-2"
    style="bottom:-100px;left:-80px;filter:blur(80px);background:radial-gradient(circle,rgba(52,211,153,0.09) 0%,transparent 70%)"></div>
  <div class="absolute w-[400px] h-[400px] rounded-full pointer-events-none will-change-transform animate-orb-3"
    style="top:30%;left:40%;filter:blur(80px);background:radial-gradient(circle,rgba(167,139,250,0.07) 0%,transparent 70%)"></div>

  <div class="max-w-[1160px] mx-auto px-8 relative z-10">

    <!-- Split: Text left, Collage right -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_480px] gap-12 lg:gap-14 items-center">

      <!-- Text Column -->
      <div>
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 border rounded-full px-4 py-1.5 text-sm font-medium text-brand-cyan mb-7 animate-badge-in"
          style="background:rgba(34,211,238,0.08);border-color:rgba(34,211,238,0.25)">
          <span class="w-2 h-2 rounded-full bg-brand-cyan animate-pulse-dot"
            style="box-shadow:0 0 8px #22D3EE"></span>
          {badge}
        </div>

        <!-- Headline -->
        <h1 class="font-heading font-black leading-[1.04] tracking-[-0.035em] mb-7"
          style="font-size: clamp(2.4rem, 5vw, 3.8rem)">
          {headline.map((line: string, i: number) => (
            i < 2
              ? <Fragment>{line}<br/></Fragment>
              : <span class="bg-clip-text text-transparent"
                  style="background-image: linear-gradient(90deg, #34D399, #22D3EE, #A78BFA)">{line}{i < headline.length - 1 ? <br/> : ''}</span>
          ))}
        </h1>

        <p class="text-brand-secondary leading-[1.8] mb-10 max-w-[520px]"
          style="font-size: clamp(1rem, 2vw, 1.1rem)">
          {subtext}
        </p>

        <div class="flex gap-4 flex-wrap">
          <a href={cta_primary.href}
            class="font-heading font-bold text-sm px-8 py-3.5 rounded-full text-white transition-all hover:-translate-y-0.5 hover:shadow-glow-cyan"
            style="background:linear-gradient(135deg,#0e9488,#0e7490,#6d28d9);background-size:200%">
            {cta_primary.label}
          </a>
          <a href={cta_secondary.href}
            class="font-heading font-semibold text-sm px-8 py-3.5 rounded-full text-brand-text border transition-all hover:border-brand-cyan hover:text-brand-cyan hover:bg-cyan-500/10"
            style="border-color:rgba(255,255,255,0.15);background:rgba(255,255,255,0.04);backdrop-filter:blur(4px)">
            {cta_secondary.label}
          </a>
        </div>
      </div>

      <!-- Floating Collage (Desktop only) -->
      {collage && (
        <div class="hidden lg:block relative" style="height:520px">

          <!-- Browser Screenshot (main, largest) -->
          {collage.browser?.src ? (
            <div class="absolute rounded-xl border border-brand-border overflow-hidden shadow-2xl"
              style="top:30px;left:20px;width:300px;height:210px;transform:rotate(-2deg);z-index:2">
              <img src={collage.browser.src} alt={collage.browser.alt}
                class="w-full h-full object-cover object-top" loading="eager" decoding="async" />
            </div>
          ) : (
            <div class="absolute rounded-xl border border-brand-border overflow-hidden shadow-2xl"
              style="top:30px;left:20px;width:300px;height:210px;transform:rotate(-2deg);z-index:2;background:rgba(39,39,42,0.7);backdrop-filter:blur(12px)">
              <div class="flex items-center gap-1.5 px-3 py-2 border-b border-brand-border">
                <span class="w-2 h-2 rounded-full" style="background:#EF4444"></span>
                <span class="w-2 h-2 rounded-full" style="background:#F59E0B"></span>
                <span class="w-2 h-2 rounded-full" style="background:#22C55E"></span>
                <span class="text-[9px] text-brand-muted ml-2 font-mono">friseursalon-mueller.de</span>
              </div>
              <div class="p-4">
                <div class="h-2 w-20 rounded-full mb-3" style="background:rgba(255,255,255,0.08)"></div>
                <div class="h-6 w-40 rounded mb-2" style="background:rgba(255,255,255,0.06)"></div>
                <div class="h-2 w-full rounded-full mb-1.5" style="background:rgba(255,255,255,0.05)"></div>
                <div class="h-2 w-3/4 rounded-full mb-3" style="background:rgba(255,255,255,0.05)"></div>
                <div class="flex gap-2">
                  <div class="h-5 w-20 rounded-full" style="background:rgba(52,211,153,0.15)"></div>
                  <div class="h-5 w-16 rounded-full" style="background:rgba(255,255,255,0.06)"></div>
                </div>
              </div>
            </div>
          )}

          <!-- Phone Mockup -->
          {collage.phone?.src ? (
            <div class="absolute rounded-2xl border-2 border-brand-border overflow-hidden shadow-2xl"
              style="top:60px;right:0;width:150px;height:280px;transform:rotate(3deg);z-index:3">
              <img src={collage.phone.src} alt={collage.phone.alt}
                class="w-full h-full object-cover" loading="eager" decoding="async" />
            </div>
          ) : (
            <div class="absolute rounded-2xl border-2 border-brand-border overflow-hidden shadow-2xl"
              style="top:60px;right:0;width:150px;height:280px;transform:rotate(3deg);z-index:3;background:rgba(39,39,42,0.8);backdrop-filter:blur(12px)">
              <div class="w-8 h-1 rounded-full mx-auto mt-2" style="background:rgba(255,255,255,0.12)"></div>
              <div class="p-3 mt-2">
                <div class="h-2 w-12 rounded-full mb-2" style="background:rgba(255,255,255,0.08)"></div>
                <div class="h-4 w-full rounded mb-2" style="background:rgba(255,255,255,0.06)"></div>
                <div class="h-16 w-full rounded mb-2" style="background:rgba(255,255,255,0.04)"></div>
                <div class="h-2 w-full rounded-full mb-1" style="background:rgba(255,255,255,0.05)"></div>
                <div class="h-2 w-3/4 rounded-full mb-3" style="background:rgba(255,255,255,0.05)"></div>
                <div class="h-5 w-full rounded-full" style="background:rgba(52,211,153,0.12)"></div>
              </div>
            </div>
          )}

          <!-- Google Review Card (floating, tilted) -->
          <div class="absolute rounded-xl border border-brand-border p-3.5 shadow-xl"
            style="bottom:140px;left:0;width:240px;transform:rotate(1.5deg);z-index:4;background:rgba(39,39,42,0.75);backdrop-filter:blur(16px)">
            <div class="flex items-center gap-1.5 mb-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <span class="text-[10px] font-heading font-semibold text-brand-heading">Google Bewertung</span>
            </div>
            <div class="flex gap-0.5 mb-1.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-[11px] text-brand-secondary leading-relaxed italic">
              "{collage.review.text}"
            </p>
            <span class="text-[9px] text-brand-muted font-heading mt-1 block">{collage.review.author}</span>
          </div>

          <!-- Stats Card (floating) -->
          <div class="absolute rounded-xl border border-brand-border px-4 py-3 shadow-lg"
            style="top:0;left:140px;transform:rotate(-1deg);z-index:5;background:rgba(39,39,42,0.75);backdrop-filter:blur(16px)">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
                style="background:rgba(52,211,153,0.12)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
                  <polyline points="16 7 22 7 22 13"/>
                </svg>
              </div>
              <div>
                <div class="font-heading font-black text-lg text-brand-emerald leading-none">{collage.stats.value}</div>
                <div class="text-[9px] text-brand-muted font-heading">{collage.stats.label}</div>
              </div>
            </div>
          </div>

          <!-- Notification Card (floating) -->
          <div class="absolute rounded-xl border border-brand-border p-3 flex items-center gap-2.5 shadow-lg"
            style="bottom:50px;right:20px;width:220px;transform:rotate(-1.5deg);z-index:4;background:rgba(39,39,42,0.75);backdrop-filter:blur(16px)">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background:rgba(52,211,153,0.12)">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"/>
              </svg>
            </div>
            <div class="min-w-0">
              <div class="text-[11px] font-heading font-bold text-brand-heading">{collage.notification.title}</div>
              <div class="text-[9px] text-brand-muted truncate">{collage.notification.text}</div>
            </div>
            <span class="text-[8px] text-brand-emerald font-heading flex-shrink-0 ml-auto">{collage.notification.time}</span>
          </div>

          <!-- Customer Photo (small, rounded, floating) -->
          {collage.customer?.src && (
            <div class="absolute rounded-full overflow-hidden border-2 border-brand-border shadow-lg"
              style="bottom:80px;left:200px;width:70px;height:70px;z-index:5">
              <img src={collage.customer.src} alt={collage.customer.alt}
                class="w-full h-full object-cover object-top" loading="eager" decoding="async" />
            </div>
          )}

        </div>
      )}

    </div>

    <!-- KPIs (full width, below split) -->
    <div class="flex mt-14 border border-brand-border rounded-card overflow-hidden">
      {kpis.map((k: any, i: number) => (
        <div class:list={['flex-1 px-6 py-5 text-center', i < kpis.length - 1 ? 'border-r border-brand-border' : '']}>
          <div class:list={['font-heading font-black text-2xl', k.color === 'emerald' ? 'text-brand-emerald' : k.color === 'cyan' ? 'text-brand-cyan' : 'text-brand-violet']}>
            {k.value}
          </div>
          <div class="text-xs text-brand-muted font-body mt-1">{k.label}</div>
        </div>
      ))}
    </div>

    <!-- Trust-Leiste -->
    {trust_items && trust_items.length > 0 && (
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mt-6">
        {trust_items.map((item: string) => (
          <span class="flex items-center gap-1.5 text-xs text-brand-secondary">
            <span class="text-brand-emerald">✔</span>{item}
          </span>
        ))}
      </div>
    )}

  </div>
</section>
