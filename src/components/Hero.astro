---
const { data } = Astro.props;
const { badge, headline, subtext, highlight, cta_primary, cta_secondary, trust_items, collage } = data;
---

<section id="hero" class="relative overflow-hidden pt-[calc(72px+60px)] pb-16">

  <!-- Subtle radial gradient accent -->
  <div class="absolute inset-0 pointer-events-none z-0"
    style="background: radial-gradient(ellipse 60% 50% at 50% 30%, rgba(16,44,38,0.04), transparent)">
  </div>

  <div class="max-w-[800px] mx-auto px-8 relative z-10 text-center">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 border rounded-full px-4 py-1.5 text-sm font-medium text-brand-emerald mb-7 animate-badge-in"
      style="background:rgba(16,44,38,0.08);border-color:rgba(16,44,38,0.20)">
      <span class="w-2 h-2 rounded-full bg-brand-emerald animate-pulse-dot"
        style="box-shadow:0 0 8px #102C26"></span>
      {badge}
    </div>

    <!-- Headline -->
    <h1 class="font-heading font-black leading-[1.08] tracking-[-0.02em] mb-5"
      style="font-size: clamp(2.2rem, 5vw, 3.6rem)">
      {headline.map((line: string, i: number) => (
        i < 2
          ? <Fragment>{line}<br/></Fragment>
          : <span style="color:#102C26">{line}{i < headline.length - 1 ? <br/> : ''}</span>
      ))}
    </h1>

    <!-- Short subtext -->
    <p class="text-brand-text leading-[1.7] mb-6 max-w-[480px] mx-auto"
      style="font-size: clamp(0.95rem, 1.8vw, 1.05rem)">
      {subtext}
    </p>

    <!-- Highlight text -->
    {highlight && (
      <p class="font-heading font-bold text-brand-emerald mb-8"
        style="font-size:clamp(1.05rem, 2vw, 1.2rem)">
        {highlight}
      </p>
    )}

    <!-- CTAs -->
    <div class="flex gap-4 flex-wrap justify-center mb-6">
      <a href={cta_primary.href}
        class="font-heading font-bold text-sm px-7 py-3 rounded-lg text-white transition-all hover:-translate-y-0.5 hover:opacity-90"
        style="background:#102C26">
        {cta_primary.label}
      </a>
      <a href={cta_secondary.href}
        class="font-heading font-semibold text-sm px-7 py-3 rounded-lg transition-all hover:bg-[#102C26] hover:text-white"
        style="border:2px solid #102C26;color:#102C26;background:transparent">
        {cta_secondary.label}
      </a>
    </div>

    <!-- Compact Trust Line -->
    {trust_items && trust_items.length > 0 && (
      <div class="flex flex-wrap justify-center gap-x-2 gap-y-1">
        {trust_items.map((item: string, i: number) => (
          <span class="flex items-center gap-1.5 text-xs text-brand-muted">
            <span class="text-brand-emerald text-[10px]">✔</span>{item}{i < trust_items.length - 1 && <span class="text-brand-border ml-1">·</span>}
          </span>
        ))}
      </div>
    )}

  </div>

  <!-- Device Mockups + Review -->
  {collage && (
    <div class="max-w-[960px] mx-auto px-8 relative z-10 mt-12">
      <div class="relative pb-8">

        <!-- ═══ DESKTOP BROWSER MOCKUP ═══ -->
        <div class="rounded-xl border border-brand-border overflow-hidden bg-white shadow-card hero-visual"
          style="animation-delay:0.15s">
          <!-- Chrome bar -->
          <div class="flex items-center gap-1.5 px-3.5 py-2 border-b border-brand-border" style="background:rgba(242,237,230,0.5)">
            <span class="w-[7px] h-[7px] rounded-full" style="background:#EF4444"></span>
            <span class="w-[7px] h-[7px] rounded-full" style="background:#F59E0B"></span>
            <span class="w-[7px] h-[7px] rounded-full" style="background:#22C55E"></span>
            <div class="flex-1 flex justify-center ml-3">
              <div class="flex items-center gap-1.5 rounded-md px-3 py-0.5" style="background:rgba(0,0,0,0.04)">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#8A8480" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span class="text-[9px] text-brand-muted font-body">hairlounge-koeln.de</span>
              </div>
            </div>
          </div>

          <!-- CSS-only website mockup -->
          <div class="mockup-site">
            <!-- Nav -->
            <div class="flex items-center justify-between px-6 py-3 border-b" style="border-color:rgba(0,0,0,0.06)">
              <div class="flex items-center gap-2">
                <div class="w-5 h-5 rounded-full" style="background:#102C26"></div>
                <span class="text-[11px] font-heading font-bold" style="color:#102C26">Hairlounge</span>
              </div>
              <div class="hidden sm:flex items-center gap-5">
                <span class="mockup-nav-link">Leistungen</span>
                <span class="mockup-nav-link">Team</span>
                <span class="mockup-nav-link">Preise</span>
                <span class="mockup-nav-link">Kontakt</span>
                <span class="text-[8px] font-heading font-bold text-white px-2.5 py-1 rounded" style="background:#102C26">Termin buchen</span>
              </div>
            </div>

            <!-- Hero area -->
            <div class="flex">
              <!-- Hero image placeholder -->
              <div class="flex-1 relative overflow-hidden" style="min-height:200px;background:linear-gradient(135deg, #f5f0eb 0%, #e8dfd6 100%)">
                <!-- Decorative circles suggesting salon imagery -->
                <div class="absolute" style="width:280px;height:280px;border-radius:50%;background:rgba(16,44,38,0.06);top:-40px;right:-60px"></div>
                <div class="absolute" style="width:160px;height:160px;border-radius:50%;background:rgba(16,44,38,0.04);bottom:20px;left:30px"></div>

                <div class="relative z-10 px-6 py-8 max-w-[55%]">
                  <span class="text-[7px] uppercase tracking-[0.15em] font-heading font-semibold" style="color:#102C26">Friseursalon Köln</span>
                  <div class="mt-2 font-heading font-black leading-[1.1]" style="font-size:clamp(14px, 2.5vw, 22px);color:#102C26">
                    Dein Style.<br/>Unsere Leidenschaft.
                  </div>
                  <div class="mt-2 text-[8px] leading-relaxed" style="color:#3D3B38">
                    Modernes Haarstyling im Herzen von Köln — professionell, entspannt & immer auf Augenhöhe.
                  </div>
                  <div class="flex gap-2 mt-3">
                    <span class="text-[7px] font-heading font-bold text-white px-2.5 py-1.5 rounded" style="background:#102C26">Termin vereinbaren →</span>
                    <span class="text-[7px] font-heading font-semibold px-2.5 py-1.5 rounded" style="border:1px solid #102C26;color:#102C26">Preise ansehen</span>
                  </div>
                </div>
              </div>

              <!-- Side image area -->
              <div class="hidden md:block w-[38%]" style="background:linear-gradient(180deg, #e0d5c9 0%, #d4c7b8 100%)">
                <div class="h-full flex items-center justify-center">
                  <!-- Abstract salon elements -->
                  <div class="relative w-full h-full">
                    <div class="absolute inset-4 rounded-lg" style="background:rgba(16,44,38,0.08)"></div>
                    <div class="absolute top-6 right-6 w-16 h-16 rounded-full" style="background:rgba(16,44,38,0.12)"></div>
                    <div class="absolute bottom-8 left-6 w-12 h-12 rounded-full" style="background:rgba(255,255,255,0.4)"></div>
                    <!-- Scissors icon -->
                    <div class="absolute inset-0 flex items-center justify-center">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#102C26" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.3">
                        <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Services strip -->
            <div class="flex border-t" style="border-color:rgba(0,0,0,0.06)">
              <div class="flex-1 px-4 py-3 text-center border-r" style="border-color:rgba(0,0,0,0.06)">
                <div class="text-[8px] font-heading font-bold" style="color:#102C26">Schnitt & Styling</div>
                <div class="text-[7px] mt-0.5" style="color:#8A8480">ab 35 €</div>
              </div>
              <div class="flex-1 px-4 py-3 text-center border-r" style="border-color:rgba(0,0,0,0.06)">
                <div class="text-[8px] font-heading font-bold" style="color:#102C26">Färben & Strähnen</div>
                <div class="text-[7px] mt-0.5" style="color:#8A8480">ab 65 €</div>
              </div>
              <div class="flex-1 px-4 py-3 text-center border-r" style="border-color:rgba(0,0,0,0.06)">
                <div class="text-[8px] font-heading font-bold" style="color:#102C26">Bartpflege</div>
                <div class="text-[7px] mt-0.5" style="color:#8A8480">ab 20 €</div>
              </div>
              <div class="hidden sm:block flex-1 px-4 py-3 text-center">
                <div class="text-[8px] font-heading font-bold" style="color:#102C26">Brautstyling</div>
                <div class="text-[7px] mt-0.5" style="color:#8A8480">auf Anfrage</div>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ PHONE MOCKUP — same brand ═══ -->
        <div class="absolute -bottom-4 right-0 sm:right-8 w-[110px] sm:w-[130px] rounded-2xl border-2 border-white overflow-hidden bg-white hero-visual"
          style="box-shadow:0 8px 30px rgba(0,0,0,0.12);animation-delay:0.3s;z-index:2">
          <!-- Phone status bar -->
          <div class="flex items-center justify-between px-2.5 py-1" style="background:#fafaf8">
            <span class="text-[6px] font-body font-semibold" style="color:#102C26">9:41</span>
            <div class="flex gap-0.5">
              <div class="w-2 h-1.5 rounded-sm" style="background:rgba(0,0,0,0.2)"></div>
              <div class="w-2 h-1.5 rounded-sm" style="background:rgba(0,0,0,0.2)"></div>
              <div class="w-3 h-1.5 rounded-sm" style="background:#102C26"></div>
            </div>
          </div>
          <!-- Phone content: booking view -->
          <div class="px-2.5 pb-3">
            <!-- Mini logo -->
            <div class="flex items-center gap-1 py-2">
              <div class="w-3 h-3 rounded-full" style="background:#102C26"></div>
              <span class="text-[7px] font-heading font-bold" style="color:#102C26">Hairlounge</span>
            </div>
            <!-- Booking heading -->
            <div class="text-[8px] font-heading font-bold mb-1.5" style="color:#102C26">Termin buchen</div>
            <!-- Service selection -->
            <div class="rounded-md p-1.5 mb-1.5" style="background:rgba(16,44,38,0.06);border:1px solid rgba(16,44,38,0.15)">
              <div class="text-[6px] font-heading font-semibold" style="color:#102C26">✓ Schnitt & Styling</div>
              <div class="text-[5px] mt-0.5" style="color:#8A8480">45 Min · 42 €</div>
            </div>
            <div class="rounded-md p-1.5 mb-2" style="background:rgba(0,0,0,0.02);border:1px solid rgba(0,0,0,0.06)">
              <div class="text-[6px] font-heading font-semibold" style="color:#3D3B38">Färben & Strähnen</div>
              <div class="text-[5px] mt-0.5" style="color:#8A8480">90 Min · 85 €</div>
            </div>
            <!-- Mini calendar -->
            <div class="text-[6px] font-heading font-semibold mb-1" style="color:#102C26">März 2026</div>
            <div class="grid grid-cols-7 gap-px mb-2">
              <span class="mockup-cal-head">Mo</span><span class="mockup-cal-head">Di</span><span class="mockup-cal-head">Mi</span><span class="mockup-cal-head">Do</span><span class="mockup-cal-head">Fr</span><span class="mockup-cal-head">Sa</span><span class="mockup-cal-head">So</span>
              <span class="mockup-cal-day" style="color:#ccc">23</span><span class="mockup-cal-day" style="color:#ccc">24</span><span class="mockup-cal-day" style="color:#ccc">25</span><span class="mockup-cal-day" style="color:#ccc">26</span><span class="mockup-cal-day" style="color:#ccc">27</span><span class="mockup-cal-day" style="color:#ccc">28</span><span class="mockup-cal-day"></span>
              <span class="mockup-cal-day">1</span><span class="mockup-cal-day">2</span><span class="mockup-cal-day">3</span><span class="mockup-cal-day">4</span><span class="mockup-cal-day mockup-cal-today">5</span><span class="mockup-cal-day">6</span><span class="mockup-cal-day">7</span>
              <span class="mockup-cal-day">8</span><span class="mockup-cal-day">9</span><span class="mockup-cal-day">10</span><span class="mockup-cal-day">11</span><span class="mockup-cal-day">12</span><span class="mockup-cal-day">13</span><span class="mockup-cal-day">14</span>
            </div>
            <!-- CTA -->
            <div class="text-[6px] font-heading font-bold text-white text-center py-1.5 rounded" style="background:#102C26">Termin bestätigen</div>
          </div>
        </div>

        <!-- ═══ GOOGLE REVIEW — floating bottom left ═══ -->
        <div class="absolute -bottom-4 left-0 sm:left-4 rounded-xl border border-brand-border p-3.5 bg-white hero-visual max-w-[240px]"
          style="box-shadow:0 8px 24px rgba(0,0,0,0.08);animation-delay:0.4s;z-index:2">
          <div class="flex items-center gap-1.5 mb-1.5">
            <svg class="w-3.5 h-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="text-[10px] font-heading font-semibold text-brand-heading">Google Bewertung</span>
            <div class="flex gap-0.5 ml-auto">
              {[1,2,3,4,5].map(() => (
                <svg class="w-2.5 h-2.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
          </div>
          <p class="text-[11px] text-brand-text leading-snug italic">
            &ldquo;{collage.review.text}&rdquo;
          </p>
          <div class="flex items-center gap-2 mt-2">
            {collage.customer?.src && (
              <img src={collage.customer.src} alt={collage.customer.alt}
                class="w-5 h-5 rounded-full object-cover object-top border border-brand-border" loading="eager" decoding="async" />
            )}
            <span class="text-[9px] text-brand-muted font-heading">{collage.review.author}</span>
          </div>
        </div>

      </div>
    </div>
  )}

</section>

<style>
  .hero-visual {
    opacity: 0;
    transform: translateY(20px);
    animation: heroReveal 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes heroReveal {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .mockup-nav-link {
    font-size: 8px;
    color: #3D3B38;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  }
  .mockup-cal-head {
    font-size: 5px;
    text-align: center;
    color: #8A8480;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  }
  .mockup-cal-day {
    font-size: 5px;
    text-align: center;
    color: #3D3B38;
    padding: 1px 0;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  }
  .mockup-cal-today {
    background: #102C26;
    color: white !important;
    border-radius: 50%;
    width: 12px;
    height: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }
</style>
