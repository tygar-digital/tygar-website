---
const { data } = Astro.props;
---
<section class="border-t border-brand-border">
  <div class="max-w-[900px] mx-auto px-8 py-16">

    <!-- Image Container -->
    <div class="relative rounded-card overflow-hidden border border-brand-border">
      <img
        src={data.src}
        alt={data.alt}
        class="w-full h-auto object-cover"
        style="max-height:420px"
        loading="lazy"
        decoding="async"
      />
      <!-- Gradient overlay bottom -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0F]/50 via-transparent to-transparent pointer-events-none"></div>
    </div>

    <!-- Caption -->
    {data.caption && (
      <p class="text-sm text-brand-secondary text-center mt-4">{data.caption}</p>
    )}

  </div>
</section>
