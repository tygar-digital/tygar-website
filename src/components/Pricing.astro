---
const { data } = Astro.props;
---
<section id="preise" class="border-t border-brand-border">
  <div class="max-w-[1160px] mx-auto px-8 py-[108px]">

    <div class="flex items-center gap-2 text-[0.72rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-secondary mb-3">
      <span class="w-[18px] h-[2px] flex-shrink-0" style="background:linear-gradient(90deg,#34D399,#22D3EE,#A78BFA)"></span>
      {data.label}
    </div>
    <h2 class="font-heading font-black leading-[1.08] tracking-[-0.03em] mb-4"
      style="font-size:clamp(2rem,4.5vw,3.25rem)">
      {data.heading[0]} <span class="bg-clip-text text-transparent"
        style="background-image:linear-gradient(90deg,#34D399,#22D3EE,#A78BFA)">{data.heading[1]}</span>
    </h2>
    <p class="text-brand-secondary leading-[1.75] mb-12 max-w-[580px]">{data.subtext}</p>

    <div class="flex flex-col gap-10">
      {data.sections.map((sec: any) => (
        <div>
          <div class="mb-4">
            <h3 class="font-heading font-bold text-brand-heading text-lg mb-1">{sec.name}</h3>
            <p class="text-brand-secondary text-sm">{sec.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-[1fr_1px_1fr] rounded-card border border-brand-border overflow-hidden"
            style="background:rgba(39,39,42,0.55);backdrop-filter:blur(12px)">

            <!-- Einmalig -->
            <div class="p-8 md:p-9">
              <div class="text-[0.68rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-muted mb-5">
                {sec.onetime.heading}
              </div>
              <ul class="flex flex-col gap-3 list-none">
                {sec.onetime.base && (
                  <>
                    <li class="flex justify-between items-center gap-3 pb-3 border-b border-brand-border font-semibold text-brand-heading">
                      <span>{sec.onetime.base.label}</span>
                      <span class="font-heading font-black text-2xl text-brand-cyan whitespace-nowrap">{sec.onetime.base.price}</span>
                    </li>
                    {sec.onetime.discounts?.map((d: any) => (
                      <li class="flex justify-between items-center gap-3 text-sm text-brand-text">
                        <span>{d.label}</span>
                        <span class="font-semibold text-brand-emerald whitespace-nowrap">{d.amount}</span>
                      </li>
                    ))}
                    {sec.onetime.extras?.map((e: any) => (
                      <li class="flex justify-between items-center gap-3 text-sm text-brand-text">
                        <span>{e.label}</span>
                        <span class="font-semibold text-brand-muted whitespace-nowrap">{e.amount}</span>
                      </li>
                    ))}
                    {sec.onetime.min_note && (
                      <li class="text-xs text-brand-muted pt-2 border-t border-brand-border">{sec.onetime.min_note}</li>
                    )}
                  </>
                )}
                {sec.onetime.items?.map((item: any) => (
                  <li class="flex justify-between items-center gap-3 text-sm text-brand-text">
                    <span>{item.label}</span>
                    <span class="font-semibold text-brand-text whitespace-nowrap">{item.amount}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Divider -->
            <div class="hidden md:block bg-brand-border"></div>
            <div class="md:hidden h-px bg-brand-border"></div>

            <!-- Monatlich -->
            <div class="p-8 md:p-9">
              <div class="text-[0.68rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-muted mb-5">
                {sec.monthly.heading}
              </div>
              {sec.monthly.price ? (
                <>
                  <div class="font-heading font-black text-brand-heading leading-none mb-1"
                    style="font-size:2.8rem">
                    {sec.monthly.price}<span class="text-base font-normal text-brand-muted"> /Monat</span>
                  </div>
                  <div class="text-xs text-brand-muted mb-5">{sec.monthly.note}</div>
                  <ul class="flex flex-col gap-2.5 list-none">
                    {sec.monthly.features?.map((f: string) => (
                      <li class="flex items-center gap-2 text-sm text-brand-text">
                        <span class="text-brand-cyan text-xs">✓</span>{f}
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <ul class="flex flex-col gap-3 list-none">
                  {sec.monthly.items?.map((item: any) => (
                    <li class="flex justify-between items-center gap-3 text-sm text-brand-text">
                      <span>{item.label}</span>
                      <span class="font-semibold whitespace-nowrap">{item.amount}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-brand-muted text-xs mt-6">{data.note}</p>
  </div>
</section>
