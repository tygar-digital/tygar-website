---
const { data } = Astro.props;
---
<section id="mission" class="bg-brand-surface">
  <div class="max-w-[1160px] mx-auto px-8 py-[108px]">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-12 items-center mb-12">
      <div>
        <div class="flex items-center gap-2 text-[0.72rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-text mb-3">
          <span class="w-[18px] h-[2px] flex-shrink-0" style="background:#2D6A4F"></span>
          {data.label}
        </div>
        <h2 class="font-heading font-black leading-[1.08] tracking-[-0.02em] mb-4"
          style="font-size:clamp(2rem,4.5vw,3.25rem)">
          {data.headline[0]}<br/>
          <span style="color:#2D6A4F">{data.headline[1]}</span>
        </h2>
        <p class="text-brand-text leading-[1.75]">{data.statement}</p>
      </div>

      {data.image && (
        <div class="hidden lg:block rounded-card overflow-hidden border border-brand-border relative shadow-card"
          style="aspect-ratio:4/3">
          <img src={data.image.src} alt={data.image.alt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent pointer-events-none"></div>
        </div>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {data.values.map((val: any) => (
        <div class="rounded-card border border-brand-border p-7 flex flex-col gap-4 bg-white shadow-card">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
            style="background:rgba(45,106,79,0.10);color:#2D6A4F"
            set:html={val.icon_svg}>
          </div>
          <h3 class="font-heading font-bold text-brand-heading">{val.title}</h3>
          <p class="text-brand-text text-sm leading-relaxed">{val.text}</p>
        </div>
      ))}
    </div>

    <div class="text-[0.72rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-text mb-4">
      {data.audience_label}
    </div>
    <div class="flex flex-wrap gap-3">
      {data.audience.map((a: any) => (
        <span class="inline-flex items-center gap-2 text-sm font-body text-brand-heading px-4 py-2 rounded-full border border-brand-border bg-white">
          <span>{a.icon}</span> {a.label}
        </span>
      ))}
    </div>
  </div>
</section>
