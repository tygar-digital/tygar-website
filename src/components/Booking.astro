---
const { data } = Astro.props;
---
<section id="termin" class="border-t border-brand-border">
  <div class="max-w-[1160px] mx-auto px-8 py-[108px]">

    <div class="flex items-center gap-2 text-[0.72rem] font-heading font-bold tracking-[0.12em] uppercase text-brand-secondary mb-3">
      <span class="w-[18px] h-[2px] flex-shrink-0" style="background:linear-gradient(90deg,#34D399,#22D3EE,#A78BFA)"></span>
      {data.label}
    </div>
    <h2 class="font-heading font-black leading-[1.08] tracking-[-0.03em] mb-4"
      style="font-size:clamp(2rem,4.5vw,3.25rem)">
      {data.heading[0]}<br/>
      <span class="bg-clip-text text-transparent"
        style="background-image:linear-gradient(90deg,#34D399,#22D3EE,#A78BFA)">{data.heading[1]}</span>
    </h2>
    <p class="text-brand-secondary leading-[1.75] mb-10 max-w-[560px]">{data.subtext}</p>

    {data.features && data.features.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        {data.features.map((feat: any) => (
          <div class="flex items-center gap-3 rounded-card border border-brand-border p-4"
            style="background:rgba(39,39,42,0.55);backdrop-filter:blur(12px)">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
              style={`background:${feat.accent === 'emerald' ? 'rgba(52,211,153,.12)' : feat.accent === 'cyan' ? 'rgba(34,211,238,.12)' : 'rgba(167,139,250,.12)'};
                      color:${feat.accent === 'emerald' ? '#34D399' : feat.accent === 'cyan' ? '#22D3EE' : '#A78BFA'}`}
              set:html={feat.icon_svg}>
            </div>
            <span class="text-sm text-brand-text font-body">{feat.text}</span>
          </div>
        ))}
      </div>
    )}

    <!-- Cal.com Inline Embed -->
    <div class="rounded-card border border-brand-border overflow-hidden"
      style="background:rgba(39,39,42,0.55)">
      <script src="https://app.cal.com/embed/embed.js" is:inline></script>
      <cal-inline cal-link={data.cal_link} style="width:100%;min-height:500px;overflow:scroll"></cal-inline>
    </div>
  </div>
</section>
